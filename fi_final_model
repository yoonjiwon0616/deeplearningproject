    X_val_solar_tensor = torch.tensor(X_val_solar_scaled, dtype=torch.float32)
    y_val_rad_tensor = torch.tensor(val_rad_scaled, dtype=torch.float32).unsqueeze(1)
    y_val_gen_tensor = torch.tensor(val_gen_efficiency, dtype=torch.float32).unsqueeze(1)

    opt_solar = optim.Adam(solar_model.parameters(), lr=1e-3)
    
    for epoch in range(151):
        solar_model.train()
        opt_solar.zero_grad()
        pred_gen, pred_rad = solar_model(X_train_solar_tensor)
        loss_total = criterion_mse(pred_rad, y_train_rad_tensor) + criterion_mse(pred_gen, y_train_gen_tensor)
        loss_total.backward()
        opt_solar.step()
        
        if epoch % 50 == 0:
            solar_model.eval()
            with torch.no_grad():
                v_gen, v_rad = solar_model(X_val_solar_tensor)
                val_loss = criterion_mse(v_rad, y_val_rad_tensor) + criterion_mse(v_gen, y_val_gen_tensor)
            print(f"   Solar Epoch {epoch}/150 - Train Loss: {loss_total.item():.4f} | Val Loss: {val_loss.item():.4f}")
            
    # [가중치 저장]
    solar_save_path = os.path.join(TARGET_DIR, "solar_power_forecast.pth")
    torch.save(solar_model.state_dict(), solar_save_path)
    print(f"-> 태양광 가중치 구글 드라이브 저장 완료: {solar_save_path}")

    # ─────────────────────────────────────────────────────────
    # [STAGE 2] 수요 예측 모델 학습 및 저장
    # ─────────────────────────────────────────────────────────
    print("\n[STAGE 2] 비대칭 가중 손실함수를 적용한 수요 예측 모델 학습 개시...")
    demand_model = DemandForecastModel(input_dim=12, hidden_dim=64)

    X_train_demand_tensor = torch.tensor(X_train_demand_scaled, dtype=torch.float32)
    y_train_demand = torch.tensor(train_set['power_consumption'].values, dtype=torch.float32).unsqueeze(1)
    
    X_val_demand_tensor = torch.tensor(X_val_demand_scaled, dtype=torch.float32)
    y_val_demand = torch.tensor(val_set['power_consumption'].values, dtype=torch.float32).unsqueeze(1)

    criterion_asymmetric = AsymmetricWeightedMSE(alpha=3.0)
    opt_demand = optim.Adam(demand_model.parameters(), lr=5e-3)

    for epoch in range(301): 
        demand_model.train()
        opt_demand.zero_grad()
        pred_demand = demand_model(X_train_demand_tensor)
        loss_demand = criterion_asymmetric(pred_demand, y_train_demand)
        loss_demand.backward()
        opt_demand.step()

        if epoch % 50 == 0:
            demand_model.eval()
            with torch.no_grad():
                val_pred = demand_model(X_val_demand_tensor)
                val_loss = criterion_asymmetric(val_pred, y_val_demand)
            
            preds_np = np.maximum(0, pred_demand.detach().cpu().numpy().flatten())
            labels_np = y_train_demand.detach().cpu().numpy().flatten()
            val_preds_np = np.maximum(0, val_pred.detach().cpu().numpy().flatten())
            val_labels_np = y_val_demand.detach().cpu().numpy().flatten()
            
            epoch_smape = calculate_smape(labels_np, preds_np)
            val_smape = calculate_smape(val_labels_np, val_preds_np)
            print(f"   Demand Epoch {epoch}/300 - Loss: {loss_demand.item():.4f} | Val Loss: {val_loss.item():.4f} | Train sMAPE: {epoch_smape:.2f}% | Val sMAPE: {val_smape:.2f}%")

    # [가중치 저장]
    demand_save_path = os.path.join(TARGET_DIR, "demand_forecast_model.pth")
    torch.save(demand_model.state_dict(), demand_save_path)
    print(f"-> 수요 예측 가중치 구글 드라이브 저장 완료: {demand_save_path}")

    # ─────────────────────────────────────────────────────────
    # [STAGE 3] 최종 테스트셋(test) 기반 추론 실행 (기존 추론 메커니즘)
    # ─────────────────────────────────────────────────────────
    solar_model.eval()
    demand_model.eval()
    pred_demands, pred_solars, net_loads = [], [], []

    print("\n[Step 3] 실제 테스트셋 기반 조건부 순부하 추론 시작...")
    for idx, row in test.iterrows():
        solar_feats = torch.tensor(X_test_solar_scaled[idx], dtype=torch.float32).unsqueeze(0)
        demand_feats = torch.tensor(X_test_demand_scaled[idx], dtype=torch.float32).unsqueeze(0)

        with torch.no_grad():
            pred_demand = demand_model(demand_feats).item()
            if row['solar_flag'] == 1:
                pred_solar_eff, _ = solar_model(solar_feats)
                pred_solar = max(0, pred_solar_eff.item() * row['solar_power_capacity'])
            else:
                pred_solar = 0.0

        net_load = max(0, pred_demand - pred_solar)
        pred_demands.append(pred_demand)
        pred_solars.append(pred_solar)
        net_loads.append(net_load)

    test['pred_demand'] = pred_demands
    test['pred_solar'] = pred_solars
    test['net_load'] = net_loads

    output_cols = ['building_number', 'date_time', 'pred_demand', 'pred_solar', 'net_load', 'solar_flag']
    final_submission = test[output_cols]
    output_path = f'{DATA_DIR}/final_net_load_prediction.csv'
    final_submission.to_csv(output_path, index=False, encoding='utf-8-sig')
    print(f"최종 예측 결과 저장 완료: {output_path}")

